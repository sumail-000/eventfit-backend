# ─────────────────────────────────────────
# EventFit Backend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB (get free cluster at mongodb.com/atlas)
MONGODB_URI=mongodb://localhost:27017/eventfit

# OpenWeatherMap API (free tier at openweathermap.org)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Unsplash API (free at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
